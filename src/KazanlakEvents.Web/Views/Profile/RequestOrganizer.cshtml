@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    ViewData["Title"] = L["RequestOrganizerTitle"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-md-7 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="mb-4">
                <h1 class="h3 fw-semibold mb-1">@L["RequestOrganizerTitle"]</h1>
                <p class="text-muted mb-0">@L["RequestOrganizerSubtitle"]</p>
            </div>

            <form asp-controller="Profile" asp-action="RequestOrganizer" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label fw-medium">@L["RequestOrganizerReasonLabel"]</label>
                    <textarea name="reason" rows="5" class="form-control"
                              placeholder="@L["RequestOrganizerReasonPlaceholder"]"
                              maxlength="500" required></textarea>
                    <div class="form-text">@L["ShortDescriptionHint"]</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="ke-btn ke-btn-primary">
                        <i class="bi bi-send me-1"></i>@L["RequestOrganizerSubmit"]
                    </button>
                    <a asp-controller="Profile" asp-action="Index" class="ke-btn ke-btn-ghost">
                        @L["Cancel"]
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
