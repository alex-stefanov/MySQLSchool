@model EventDetailViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{ ViewData["Title"] = Model.Title; }

@{
    // Category gradient (same logic as _EventCard)
    var catLow = (Model.CategoryName ?? "").ToLowerInvariant();
    var heroGradient = catLow switch
    {
        var c when c.Contains("concert") || c.Contains("music") => "linear-gradient(135deg,#c7d2fe,#818cf8)",
        var c when c.Contains("workshop") || c.Contains("train") => "linear-gradient(135deg,#a7f3d0,#34d399)",
        var c when c.Contains("sport") || c.Contains("run")      => "linear-gradient(135deg,#fde68a,#f59e0b)",
        var c when c.Contains("volunteer")                        => "linear-gradient(135deg,#a5f3fc,#22d3ee)",
        var c when c.Contains("art") || c.Contains("exhib")      => "linear-gradient(135deg,#fecdd3,#fb7185)",
        _                                                          => "linear-gradient(135deg,#e2e8f0,#94a3b8)"
    };

    // Organizer initials
    var orgParts   = (Model.OrganizerName ?? "").Split(new[]{' ','.'}, 2, StringSplitOptions.RemoveEmptyEntries);
    var orgInitials = orgParts.Length >= 2 && orgParts[0].Length > 0 && orgParts[1].Length > 0
        ? $"{char.ToUpper(orgParts[0][0])}{char.ToUpper(orgParts[1][0])}"
        : Model.OrganizerName?.Length > 0 ? char.ToUpper(Model.OrganizerName[0]).ToString() : "?";

    // User initials (for comment input avatar)
    var me       = User.Identity?.Name ?? "";
    var meP      = me.Split(new[]{' ','.'}, 2, StringSplitOptions.RemoveEmptyEntries);
    var meInit   = meP.Length >= 2 ? $"{char.ToUpper(meP[0][0])}{char.ToUpper(meP[1][0])}" : me.Length > 0 ? char.ToUpper(me[0]).ToString() : "?";

    bool hasMap      = Model.Latitude.HasValue && Model.Longitude.HasValue;
    bool isCompleted = Model.Status == EventStatus.Completed;
    bool canManage   = Model.IsOrganizer || User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
}

@section Styles {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "Event",
    "name": "@Html.Raw(Model.Title.Replace("\"","\\\""))",
    "description": "@Html.Raw((Model.ShortDescription ?? Model.Description ?? "").Replace("\"","\\\""))",
    "startDate": "@Model.StartDate.ToString("o")",
    "endDate": "@Model.EndDate.ToString("o")",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode"
    @if (Model.VenueName != null) {
    <text>,"location":{"@@type":"Place","name":"@Html.Raw(Model.VenueName.Replace("\"","\\\""))","address":"@Html.Raw((Model.VenueAddress??"").Replace("\"","\\\""))"}</text>
    }
    @if (Model.CoverImageUrl != null) {
    <text>,"image":"@Model.CoverImageUrl"</text>
    }
    ,"organizer":{"@@type":"Organization","name":"@Html.Raw((Model.OrganizerName ?? "").Replace("\"","\\\""))"}
    @if (!Model.IsFree && Model.TicketTypes.Any()) {
    <text>,"offers":{"@@type":"Offer","price":"@Model.TicketTypes.Min(t=>t.Price)","priceCurrency":"EUR","availability":"https://schema.org/InStock","url":"@Context.Request.GetDisplayUrl()"}</text>
    }
}
</script>
@if (hasMap) {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}
<link rel="stylesheet" href="~/css/pages/event-details.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/components/comment-item.css" asp-append-version="true" />
}

<nav class="ke-breadcrumb" aria-label="Breadcrumb">
    <div class="ke-pg ke-breadcrumb-inner">
        <a asp-controller="Event" asp-action="Index">@L["Events"]</a>
        <span class="ke-breadcrumb-sep">/</span>
        <a asp-controller="Event" asp-action="Index" asp-route-categoryId="">@Model.CategoryName</a>
        <span class="ke-breadcrumb-sep">/</span>
        <span class="ke-breadcrumb-current">@(Model.Title.Length > 60 ? Model.Title[..60] + "…" : Model.Title)</span>
    </div>
</nav>

<div class="ke-pg">
<div class="ke-hero-wrap">
    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
    {
        <img src="@Model.CoverImageUrl" alt="@Model.Title" class="ke-hero-img" />
    }
    else
    {
        <div class="ke-hero-placeholder" style="background:@heroGradient;"></div>
    }
    <div class="ke-hero-overlay"></div>

    <div class="ke-hero-actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Event" asp-action="ToggleFavorite" method="post" class="ke-admin-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="eventId" value="@Model.Id" />
                <button type="submit" class="ke-hero-btn"
                        title="@L["Favorite"].Value"
                        aria-label="@L["Favorite"].Value">
                    <svg width="16" height="16" viewBox="0 0 24 24"
                         fill="@(Model.IsFavorited ? "white" : "none")"
                         stroke="white" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </button>
            </form>
        }
    </div>

    <div class="ke-hero-badges">
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <span class="badge-category">
                @if (!string.IsNullOrEmpty(Model.CategoryIcon))
                {
                    <i class="bi @Model.CategoryIcon me-1"></i>
                }
                @Model.CategoryName
            </span>
        }
        @if (Model.IsFree)
        {
            <span class="badge-free">@L["Free"]</span>
        }
        @if (Model.Status == EventStatus.Cancelled)
        {
            <span class="ke-badge-cancelled">@L["Cancelled"]</span>
        }
    </div>
</div>

<div class="ke-details-grid">

    <div class="ke-details-main">

        @if (Model.SeriesId.HasValue)
        {
            <div class="ke-series-notice">
                <i class="bi bi-collection-fill"></i>
                <span>@L["PartOfSeries"]</span>
                <a asp-action="Series" asp-route-seriesId="@Model.SeriesId">@(Model.SeriesTitle ?? L["ViewSeries"].Value)</a>
            </div>
        }

        <h1 class="ke-event-title">@Model.Title</h1>

        <div class="ke-meta-row">
            <span class="ke-meta-date">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                </svg>
                @Model.StartDate.ToString("dd MMM yyyy, HH:mm")
                @if (Model.EndDate > Model.StartDate)
                {
                    <span class="ke-meta-end-time">– @Model.EndDate.ToString("HH:mm")</span>
                }
            </span>
            @if (!string.IsNullOrEmpty(Model.VenueName))
            {
                <span class="ke-meta-sep">|</span>
                <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                    @Model.VenueName@(Model.VenueCity != null ? $", {Model.VenueCity}" : "")
                </span>
            }
            @if (Model.Capacity.HasValue)
            {
                <span class="ke-meta-sep">|</span>
                <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    </svg>
                    @L["Capacity"]: @Model.Capacity
                </span>
            }
            @if (Model.MinAge.HasValue && Model.MinAge > 0)
            {
                <span class="ke-meta-sep">|</span>
                <span>@Model.MinAge+</span>
            }
            @if (Model.IsAccessible)
            {
                <span title="Accessible">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ke-primary)" stroke-width="2">
                        <circle cx="12" cy="5" r="2"/><path d="M12 7v6l-3 5M9 14h6M15 18l2 3"/>
                    </svg>
                </span>
            }
        </div>

        @if (canManage)
        {
            <div class="ke-admin-bar">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="ke-admin-link">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    @L["Edit"]
                </a>
                <a asp-action="CheckIn" asp-route-id="@Model.Id" class="ke-admin-link">
                    <i class="bi bi-qr-code-scan"></i>@L["CheckInScanner"]
                </a>
                <form asp-action="Delete" method="post" class="ke-admin-form" id="ke-delete-event-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="button" class="ke-admin-link danger"
                            data-confirm-title="@L["Delete"].Value"
                            data-confirm-text="@L["ConfirmDelete"].Value"
                            data-confirm-btn="@L["Delete"].Value"
                            data-confirm-form="ke-delete-event-form">
                        <i class="bi bi-trash"></i>@L["Delete"]
                    </button>
                </form>
            </div>
        }

        <div class="ke-org-card">
            <a asp-controller="Profile" asp-action="Index" asp-route-id="@Model.OrganizerId"
               class="ke-org-link">
                <div class="ke-org-avatar">
                    @if (!string.IsNullOrEmpty(Model.OrganizerAvatarUrl))
                    {
                        <img src="@Model.OrganizerAvatarUrl" alt="@Model.OrganizerName" />
                    }
                    else
                    {
                        @orgInitials
                    }
                </div>
                <div class="ke-org-info">
                    <div class="ke-org-meta">@L["OrganizedBy"]</div>
                    <div class="ke-org-name">@(string.IsNullOrEmpty(Model.OrganizerName) ? "—" : Model.OrganizerName)</div>
                </div>
            </a>
            @if (User.Identity?.IsAuthenticated == true && !Model.IsOrganizer
                 && Model.OrganizerId != Guid.Empty
                 && !string.IsNullOrEmpty(Model.OrganizerName) && Model.OrganizerName != "—")
            {
                <form asp-controller="Profile" asp-action="Follow" method="post" class="ke-admin-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.OrganizerId" />
                    <button type="submit" class="ke-follow-btn">@L["FollowUser"]</button>
                </form>
            }
        </div>

        @if (Model.Images.Any())
        {
            <div class="ke-gallery-strip" id="ke-gallery-strip">
                @foreach (var img in Model.Images)
                {
                    <img src="@(img.ThumbnailUrl ?? img.ImageUrl)"
                         data-full="@img.ImageUrl"
                         class="ke-gallery-thumb"
                         alt="@(img.Caption ?? Model.Title)" />
                }
            </div>
        }

        <div class="ke-section">
            <h3 class="ke-section-title">@L["AboutThisEvent"]</h3>
            <div class="ke-about-text">@Html.Raw(Model.Description)</div>
        </div>

        @if (Model.Tags.Any())
        {
            <div class="ke-tags-wrap">
                <div class="ke-tags">
                    @foreach (var tag in Model.Tags)
                    {
                        <a href="/Event?tag=@Uri.EscapeDataString(tag)" class="ke-tag">#@tag</a>
                    }
                </div>
            </div>
        }

        @if (hasMap)
        {
            <div class="ke-section ke-section--flush">
                <div id="ke-detail-map"
                     data-lat="@Model.Latitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                     data-lng="@Model.Longitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                     data-popup="@Html.Raw((Model.VenueName ?? Model.Title).Replace("\"","\\\""))">
                </div>
            </div>
        }

        <div class="ke-section ke-section--mt">
            <h3 class="ke-section-title">@L["Comments"] (@Model.Comments.Count)</h3>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="ke-comment-input-row">
                    <div class="ke-comment-avatar">@meInit</div>
                    <form asp-controller="Event" asp-action="AddComment" method="post"
                          class="ke-chat-input-wrap" id="ke-main-comment-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventId" value="@Model.Id" />
                        <textarea name="content" id="ke-main-textarea"
                                  class="ke-chat-textarea" rows="1"
                                  placeholder="@L["WriteComment"]" required></textarea>
                        <button type="submit" class="ke-chat-send" id="ke-main-send" aria-label="@L["Post"]">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <p class="ke-comment-login-prompt">
                    <a asp-controller="Account" asp-action="Login">@L["Login"]</a>@L["ToLeaveComment"]
                </p>
            }

            @if (!Model.Comments.Any())
            {
                <div class="ke-no-comments">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    <span>@L["NoComments"]</span>
                </div>
            }
            else
            {
                @foreach (var comment in Model.Comments)
                {
                    @await Html.PartialAsync("_CommentItem", comment,
                        new ViewDataDictionary(ViewData) { { "EventId", Model.Id }, { "Depth", 0 } })
                }
            }
        </div>

        @if (isCompleted && User.Identity?.IsAuthenticated == true)
        {
            <div class="ke-section">
                <h3 class="ke-section-title">@L["RateThisEvent"]</h3>
                @if (Model.CurrentUserRating.HasValue)
                {
                    <div class="ke-user-rating-display">
                        <span class="ke-user-rating-label">@L["YouRated"]</span>
                        <span class="ke-user-rating-value">@Model.CurrentUserRating / 5</span>
                        <div class="ke-user-rating-stars">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <svg width="18" height="18" viewBox="0 0 24 24"
                                     fill="@(s <= Model.CurrentUserRating.Value ? "#f59e0b" : "#d1d5db")"
                                     stroke="none">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <form asp-controller="Event" asp-action="RateEvent" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventId" value="@Model.Id" />
                        <input type="hidden" name="score" id="ke-score-input" required />
                        <label class="ke-rating-label-text">@L["YourRating"]</label>
                        <div class="ke-star-row" id="ke-star-picker">
                            @for (int s = 1; s <= 5; s++) {
                                <span class="ke-star-pick" data-val="@s">★</span>
                            }
                        </div>
                        <div class="ke-field--mb">
                            <textarea name="reviewText" class="ke-comment-textarea"
                                      rows="2" placeholder="@L["ReviewText"].Value"></textarea>
                        </div>
                        <button type="submit" class="ke-comment-submit">@L["SubmitRating"]</button>
                    </form>
                }
            </div>
        }

    </div>

    <aside class="ke-details-sidebar">

        @if (Model.TicketTypes?.Any() == true && Model.Status == EventStatus.Published)
        {
        <div class="ke-ticket-card">
            <h3 class="ke-section-title">@L["Registration"]</h3>

            @foreach (var tt in Model.TicketTypes)
            {
                <div class="ke-ticket-row">
                    <div>
                        <div class="ke-ticket-name">@tt.Name</div>
                        @if (!string.IsNullOrEmpty(tt.Description))
                        {
                            <div class="ke-ticket-desc">@tt.Description</div>
                        }
                    </div>
                    <div class="ke-ticket-avail">
                        @if (tt.IsAvailable)
                        {
                            @(tt.AvailableQuantity + " ")  @L["SpotsLeft"]
                        }
                        else
                        {
                            <span class="ke-ticket-sold-out">@L["SoldOut"]</span>
                        }
                    </div>
                </div>
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post" asp-controller="Event" asp-action="RegisterForEvent">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="eventId" value="@Model.Id" />
                    @if (Model.TicketTypes.Count > 1)
                    {
                        <div class="ke-field--mb">
                            <label class="ke-ticket-label">@L["RegistrationType"]</label>
                            <select name="ticketTypeId" class="ke-select">
                                @foreach (var tt in Model.TicketTypes.Where(t => t.IsAvailable))
                                {
                                    <option value="@tt.Id">@tt.Name (@tt.AvailableQuantity @L["SpotsLeft"])</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="ticketTypeId" value="@Model.TicketTypes.First().Id" />
                    }
                    @{
                        var maxQty = Model.TicketTypes.Where(t => t.IsAvailable).Select(t => t.AvailableQuantity).FirstOrDefault();
                        var maxAllowed = Math.Max(0, 5 - Model.UserCurrentTicketCount);
                        var dropdownMax = Math.Min(maxAllowed, maxQty);
                    }
                    @if (Model.UserCurrentTicketCount > 0)
                    {
                        <p class="ke-max-tickets-hint">
                            <i class="bi bi-info-circle me-1"></i>
                            @string.Format(L["MaxTicketsHint"].Value, Model.UserCurrentTicketCount)
                        </p>
                    }
                    <div class="ke-field--mb">
                        <label class="ke-ticket-label">@L["Quantity"]</label>
                        <select name="quantity" class="ke-select">
                            @for (int i = 1; i <= dropdownMax; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                    @if (dropdownMax <= 0)
                    {
                        <div class="ke-cta-btn ke-cta-btn-disabled">
                            @(maxAllowed <= 0 ? L["MaxFiveTicketsPerEvent"] : L["SoldOut"])
                        </div>
                    }
                    else if (Model.TicketTypes.Any(t => t.IsAvailable))
                    {
                        <button type="submit" class="ke-cta-btn ke-cta-btn-free">
                            @L["RegisterNow"]
                        </button>
                    }
                    else
                    {
                        <div class="ke-cta-btn ke-cta-btn-disabled">
                            @L["SoldOut"]
                        </div>
                    }
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   asp-route-returnUrl="@Context.Request.Path"
                   class="ke-cta-btn ke-cta-btn-login">
                    @L["LoginToRegister"]
                </a>
            }
        </div>
        }

        <div class="ke-stats-card">
            <div class="ke-stats-3">
                <div>
                    <div class="ke-stat-n">@Model.AttendeeCount</div>
                    <div class="ke-stat-l">@L["Going"]</div>
                </div>
                <div>
                    <div class="ke-stat-n ke-stat-n--warning">@Model.AverageRating.ToString("F1")</div>
                    <div class="ke-stat-l">@L["Ratings"]</div>
                </div>
                <div>
                    <div class="ke-stat-n">@Model.ViewCount</div>
                    <div class="ke-stat-l">@L["Views"]</div>
                </div>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true && Model.Status == EventStatus.Published)
        {
            <div class="ke-attend-row">
                <form asp-controller="Event" asp-action="SetAttendance" method="post" class="ke-attend-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="eventId" value="@Model.Id" />
                    <input type="hidden" name="status" value="@AttendanceStatus.Going" />
                    <button type="submit" class="ke-attend-btn @(Model.UserAttendance == AttendanceStatus.Going ? "going" : "")">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        @L["Going"]
                    </button>
                </form>
                <form asp-controller="Event" asp-action="SetAttendance" method="post" class="ke-attend-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="eventId" value="@Model.Id" />
                    <input type="hidden" name="status" value="@AttendanceStatus.Interested" />
                    <button type="submit" class="ke-attend-btn @(Model.UserAttendance == AttendanceStatus.Interested ? "interested" : "")">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                        @L["Interested"]
                    </button>
                </form>
            </div>
        }

        @if (Model.RatingCount > 0)
        {
            <div class="ke-rating-card">
                <div class="ke-rating-stars">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24"
                             fill="@(s <= Math.Round(Model.AverageRating) ? "#f59e0b" : "#e5e7eb")"
                             stroke="none">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                    }
                </div>
                <div>
                    <span class="ke-rating-avg">@Model.AverageRating.ToString("F1")</span>
                    <div class="ke-rating-cnt">@Model.RatingCount @L["Ratings"].Value.ToLower()</div>
                </div>
            </div>
        }

        <div class="ke-share-row">
            @{
                var encodedUrl   = Uri.EscapeDataString(Context.Request.GetDisplayUrl());
                var encodedTitle = Uri.EscapeDataString(Model.Title);
            }
            <button class="ke-share-btn" type="button">
                <a href="https://www.facebook.com/sharer/sharer.php?u=@encodedUrl"
                   target="_blank" rel="noopener">
                    <i class="bi bi-facebook"></i> Facebook
                </a>
            </button>
            <button class="ke-share-btn" type="button">
                <a href="https://twitter.com/intent/tweet?text=@encodedTitle&url=@encodedUrl"
                   target="_blank" rel="noopener">
                    <i class="bi bi-twitter-x"></i> Twitter
                </a>
            </button>
            <button class="ke-share-btn" type="button" id="ke-copy-link-btn"
                    data-copied-text="@L["Copied"].Value">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
                @L["CopyLink"]
            </button>
        </div>

        @if (Model.HasVolunteerTasks || canManage)
        {
        <div class="ke-mini-card">
            <div class="ke-mini-title">@L["Volunteer"]</div>
            @if (Model.HasVolunteerTasks)
            {
                <a asp-controller="Volunteer" asp-action="EventTasks" asp-route-eventId="@Model.Id"
                   class="ke-volunteer-btn">
                    <i class="bi bi-clipboard-check me-1"></i>@L["ViewVolunteerTasks"]
                </a>
            }
            @if (canManage)
            {
                <a asp-controller="Volunteer" asp-action="ManageTasks" asp-route-eventId="@Model.Id"
                   class="ke-volunteer-btn">
                    <i class="bi bi-clipboard2-plus me-1"></i>@L["ManageTasks"]
                </a>
            }
        </div>
        }

        @if (Model.Sponsors.Any())
        {
            <div class="ke-mini-card">
                <div class="ke-mini-title">@L["EventSponsors"]</div>
                @foreach (var sp in Model.Sponsors)
                {
                    <div class="ke-sponsor-item">
                        @if (!string.IsNullOrEmpty(sp.LogoUrl))
                        {
                            <img src="@sp.LogoUrl" alt="@sp.Name" class="ke-sponsor-logo" />
                        }
                        @if (!string.IsNullOrEmpty(sp.WebsiteUrl))
                        {
                            <a asp-controller="Sponsor" asp-action="EventSponsorClick"
                               asp-route-eventId="@Model.Id" asp-route-sponsorId="@sp.Id"
                               class="ke-sponsor-name" target="_blank" rel="noopener">@sp.Name</a>
                        }
                        else
                        {
                            <span class="ke-sponsor-name">@sp.Name</span>
                        }
                    </div>
                }
            </div>
        }

    </aside>

</div>
</div>

<div class="ke-lightbox" id="ke-lightbox">
    <button class="ke-lightbox-close" aria-label="Close">×</button>
    <button class="ke-lightbox-prev" id="ke-lb-prev">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <img src="" alt="" class="ke-lightbox-img" id="ke-lb-img" />
    <button class="ke-lightbox-next" id="ke-lb-next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
</div>

@section Scripts {
    @if (hasMap) {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    }
    <script src="~/js/pages/event-details.js" asp-append-version="true"></script>
}
