@model IReadOnlyList<KazanlakEvents.Web.ViewModels.Event.MyEventViewModel>
@using KazanlakEvents.Domain.Enums
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    ViewData["Title"] = L["MyEvents"].Value;
    var currentUserId = Guid.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);

    var pending = Model.Where(e => e.Status == EventStatus.PendingApproval).ToList();
    var active  = Model.Where(e => e.Status != EventStatus.PendingApproval).ToList();

    string BadgeCss(EventStatus s) => s switch
    {
        EventStatus.Published       => "bg-success",
        EventStatus.PendingApproval => "bg-warning text-dark",
        EventStatus.Draft           => "bg-secondary",
        EventStatus.Approved        => "bg-info text-dark",
        EventStatus.Rejected        => "bg-danger",
        EventStatus.Cancelled       => "bg-danger",
        EventStatus.Completed       => "bg-primary",
        EventStatus.Ongoing         => "bg-success",
        _                           => "bg-secondary"
    };

    string StatusLabel(EventStatus s) => s switch
    {
        EventStatus.Published       => L["StatusPublished"].Value,
        EventStatus.PendingApproval => L["PendingApproval"].Value,
        EventStatus.Draft           => L["StatusDraft"].Value,
        EventStatus.Approved        => L["StatusApproved"].Value,
        EventStatus.Rejected        => L["EventRejected"].Value,
        EventStatus.Cancelled       => L["Cancelled"].Value,
        EventStatus.Completed       => L["Completed"].Value,
        EventStatus.Ongoing         => L["Ongoing"].Value,
        _                           => s.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-collection me-2 text-primary"></i>@L["MyEvents"]
    </h2>
    <a asp-action="Create" class="ke-btn ke-btn-primary">
        <i class="bi bi-plus-lg me-1"></i>@L["CreateEvent"]
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-calendar-x" style="font-size:3rem"></i>
            <p class="mt-3 mb-2 fs-5 fw-semibold">@L["NoMyEvents"]</p>
            <p class="mb-3 small">@L["NoMyEventsHint"]</p>
            <a asp-action="Create" class="ke-btn ke-btn-primary">
                <i class="bi bi-plus-lg me-1"></i>@L["CreateEvent"]
            </a>
        </div>
    </div>
}
else
{
    @if (pending.Any())
    {
        <h5 class="fw-semibold text-warning mb-3 mt-2">
            <i class="bi bi-hourglass-split me-2"></i>@L["PendingApproval"]
        </h5>
        <div class="d-flex flex-column gap-3 mb-4">
            @foreach (var ev in pending)
            {
                bool isOwner = ev.OrganizerId == currentUserId;
                <div class="card shadow-sm border border-warning border-opacity-25">
                    <div class="card-body d-flex align-items-center gap-3 p-3">

                        @if (!string.IsNullOrEmpty(ev.CoverImageUrl))
                        {
                            <img src="@ev.CoverImageUrl" alt="@ev.Title"
                                 class="rounded flex-shrink-0"
                                 style="width:80px;height:80px;object-fit:cover" />
                        }
                        else
                        {
                            <div class="rounded bg-light d-flex align-items-center justify-content-center flex-shrink-0 text-muted"
                                 style="width:80px;height:80px">
                                <i class="bi bi-image" style="font-size:1.8rem"></i>
                            </div>
                        }

                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                <a asp-action="Details" asp-route-slug="@ev.Slug"
                                   class="fw-semibold text-decoration-none text-body"
                                   style="font-size:1rem">@ev.Title</a>
                                <span class="badge @BadgeCss(ev.Status)" style="font-size:.72rem">@StatusLabel(ev.Status)</span>
                            </div>
                            <div class="text-muted small">
                                <i class="bi bi-calendar3 me-1"></i>
                                @ev.StartDate.ToString("dd MMM yyyy, HH:mm")
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-1 align-items-end flex-shrink-0">
                            @if (isOwner || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <a asp-action="Edit" asp-route-id="@ev.Id"
                                   class="ke-btn ke-btn-ghost ke-btn-sm">
                                    <i class="bi bi-pencil me-1"></i>@L["Edit"]
                                </a>
                            }
                        </div>

                    </div>
                </div>
            }
        </div>
    }

    @if (active.Any())
    {
        <h5 class="fw-semibold text-success mb-3 mt-2">
            <i class="bi bi-calendar-check me-2"></i>@L["ActiveEvents"]
        </h5>
        <div class="d-flex flex-column gap-3 mb-4">
            @foreach (var ev in active)
            {
                bool isOwner = ev.OrganizerId == currentUserId;
                <div class="card shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3 p-3">

                        @if (!string.IsNullOrEmpty(ev.CoverImageUrl))
                        {
                            <img src="@ev.CoverImageUrl" alt="@ev.Title"
                                 class="rounded flex-shrink-0"
                                 style="width:80px;height:80px;object-fit:cover" />
                        }
                        else
                        {
                            <div class="rounded bg-light d-flex align-items-center justify-content-center flex-shrink-0 text-muted"
                                 style="width:80px;height:80px">
                                <i class="bi bi-image" style="font-size:1.8rem"></i>
                            </div>
                        }

                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                <a asp-action="Details" asp-route-slug="@ev.Slug"
                                   class="fw-semibold text-decoration-none text-body"
                                   style="font-size:1rem">@ev.Title</a>
                                <span class="badge @BadgeCss(ev.Status)" style="font-size:.72rem">@StatusLabel(ev.Status)</span>
                            </div>
                            <div class="text-muted small mb-2">
                                <i class="bi bi-calendar3 me-1"></i>
                                @ev.StartDate.ToString("dd MMM yyyy, HH:mm")
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill bg-light text-dark border">
                                    <i class="bi bi-ticket me-1 text-primary"></i>
                                    @ev.TicketsSold @L["TicketsSold"]
                                </span>
                                <span class="badge rounded-pill bg-light text-dark border">
                                    <i class="bi bi-person-check me-1 text-info"></i>
                                    @ev.AttendeeCount @L["Going"]
                                </span>
                                @if (ev.HasVolunteerTasks)
                                {
                                    <span class="badge rounded-pill bg-light text-dark border">
                                        <i class="bi bi-hand-thumbs-up me-1 text-warning"></i>
                                        @ev.VolunteerCount @L["Volunteers"]
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-1 align-items-end flex-shrink-0">
                            <a asp-action="Details" asp-route-slug="@ev.Slug"
                               class="ke-btn ke-btn-ghost ke-btn-sm">
                                <i class="bi bi-eye me-1"></i>@L["View"]
                            </a>
                            @if (isOwner || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <a asp-action="Edit" asp-route-id="@ev.Id"
                                   class="ke-btn ke-btn-ghost ke-btn-sm">
                                    <i class="bi bi-pencil me-1"></i>@L["Edit"]
                                </a>
                            }
                            @if (ev.HasVolunteerTasks)
                            {
                                <a asp-controller="Volunteer" asp-action="ManageTasks"
                                   asp-route-eventId="@ev.Id"
                                   class="ke-btn ke-btn-ghost ke-btn-sm">
                                    <i class="bi bi-people me-1"></i>@L["ManageVolunteers"]
                                </a>
                            }
                        </div>

                    </div>
                </div>
            }
        </div>
    }
}
