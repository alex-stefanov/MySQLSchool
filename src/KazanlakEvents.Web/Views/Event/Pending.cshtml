@model EventListViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    Layout = "_AdminLayout";
    ViewData["AdminPage"] = "Events";
    ViewData["Title"] = L["PendingApproval"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        @L["PendingApproval"]
        @if (Model.TotalCount > 0)
        {
            <span class="badge ms-2 align-middle"
                  style="background:rgba(245,158,11,.15);color:#d97706;font-size:.7rem;font-weight:600;border-radius:20px;padding:4px 10px;vertical-align:middle;">
                @Model.TotalCount
            </span>
        }
    </h1>
    <a asp-action="Index" class="ke-btn ke-btn-ghost ke-btn-sm">
        <i class="bi bi-arrow-left"></i>@L["BackToEvents"]
    </a>
</div>

@if (!Model.Events.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-check-circle fs-1 d-block mb-3" style="color:#10b981;opacity:.6;"></i>
        <p class="mb-0 fw-semibold" style="color:var(--ke-text-secondary);">@L["NoPendingEvents"]</p>
        <p class="small mt-1" style="color:var(--ke-text-muted);">@L["NoPendingEventsHint"]</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var ev in Model.Events)
        {
            <div class="card" style="border:1px solid var(--ke-border);background:var(--ke-surface);">
                <div class="card-body p-3">
                    <div class="d-flex gap-3 align-items-start">

                        @if (!string.IsNullOrEmpty(ev.CoverImageUrl))
                        {
                            <img src="@ev.CoverImageUrl" alt=""
                                 style="width:72px;height:72px;object-fit:cover;border-radius:10px;flex-shrink:0;" />
                        }
                        else
                        {
                            <div style="width:72px;height:72px;border-radius:10px;background:var(--ke-surface-secondary);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-calendar-event" style="font-size:24px;color:var(--ke-text-muted);"></i>
                            </div>
                        }

                        <div class="flex-grow-1 min-width-0">
                            <div class="fw-semibold mb-1" style="color:var(--ke-text);font-size:.95rem;">@ev.Title</div>
                            <div class="d-flex flex-wrap gap-2 align-items-center small" style="color:var(--ke-text-secondary);">
                                @if (!string.IsNullOrEmpty(ev.OrganizerName))
                                {
                                    <span>
                                        <i class="bi bi-person me-1"></i>@ev.OrganizerName
                                    </span>
                                    <span style="color:var(--ke-border);">·</span>
                                }
                                <span>
                                    <i class="bi bi-calendar3 me-1"></i>@ev.StartDate.ToString("dd.MM.yyyy")
                                </span>
                                @if (ev.SubmittedAt.HasValue)
                                {
                                    <span style="color:var(--ke-border);">·</span>
                                    <span>
                                        <i class="bi bi-clock me-1"></i>@L["Submitted"]: @ev.SubmittedAt.Value.ToString("dd.MM.yyyy")
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(ev.CategoryName))
                                {
                                    <span style="color:var(--ke-border);">·</span>
                                    <span class="badge rounded-pill"
                                          style="background:rgba(99,102,241,.12);color:#6366f1;font-weight:500;">
                                        @if (!string.IsNullOrEmpty(ev.CategoryIcon))
                                        {
                                            <i class="bi @ev.CategoryIcon me-1"></i>
                                        }
                                        @ev.CategoryName
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(ev.ShortDescription))
                            {
                                <p class="small mb-0 mt-1" style="color:var(--ke-text-muted);overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;">
                                    @ev.ShortDescription
                                </p>
                            }
                        </div>

                        <div class="d-flex gap-2 flex-shrink-0 align-items-start">
                            <a asp-action="Details" asp-route-slug="@ev.Slug"
                               class="ke-btn ke-btn-ghost ke-btn-sm" target="_blank"
                               title="@L["View"].Value">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form asp-action="Approve" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ev.Id" />
                                <button type="submit" class="ke-btn ke-btn-success ke-btn-sm">
                                    <i class="bi bi-check-lg"></i>@L["Approve"]
                                </button>
                            </form>
                            <button type="button" class="ke-btn ke-btn-danger ke-btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#rejectModal-@ev.Id">
                                <i class="bi bi-x-lg"></i>@L["Reject"]
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Pending" asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Pending" asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Pending" asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }

    @foreach (var ev in Model.Events)
    {
        <div class="modal fade" id="rejectModal-@ev.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" style="background:var(--ke-surface);border:1px solid var(--ke-border);">
                    <div class="modal-header" style="background:rgba(239,68,68,.08);border-bottom:1px solid var(--ke-border);">
                        <h5 class="modal-title fw-semibold" style="color:#ef4444;">
                            <i class="bi bi-x-circle me-2"></i>@L["RejectConfirm"]
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="Reject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@ev.Id" />
                        <div class="modal-body">
                            <p class="fw-semibold mb-3" style="color:var(--ke-text);">@ev.Title</p>
                            <div class="mb-3">
                                <label for="reason-@ev.Id" class="form-label fw-semibold small">@L["RejectReason"]</label>
                                <textarea name="reason" id="reason-@ev.Id" class="form-control" rows="4"
                                          placeholder="@L["RejectReasonPlaceholder"].Value" required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer" style="border-top:1px solid var(--ke-border);">
                            <button type="button" class="ke-btn ke-btn-ghost ke-btn-sm" data-bs-dismiss="modal">
                                @L["Cancel"]
                            </button>
                            <button type="submit" class="ke-btn ke-btn-danger ke-btn-sm">
                                <i class="bi bi-x-lg"></i>@L["Reject"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
