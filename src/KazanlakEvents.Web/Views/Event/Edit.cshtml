@model EventEditViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{ ViewData["Title"] = L["Edit"].Value + " — " + Model.Title; }

@section Styles {
<link rel="stylesheet" href="~/css/pages/event-edit.css" asp-append-version="true" />
}

@foreach (var img in Model.ExistingImages)
{
    <form id="del-@img.Id" asp-action="DeleteImage" method="post" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="imageId" value="@img.Id" />
    </form>
}

<form id="upload-form" asp-action="UploadImages" method="post" enctype="multipart/form-data" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="eventId" value="@Model.Id" />
</form>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>@L["Edit"]</h2>
    <a asp-action="Index" class="ke-btn ke-btn-ghost ke-btn-sm">
        <i class="bi bi-arrow-left"></i>@L["BackToEvents"]
    </a>
</div>

<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

<div class="d-flex align-items-start mb-4 px-1">
    @{
        var stepLabels = new[] {
            L["WizardStep1"].Value, L["WizardStep2"].Value,
            L["WizardStep3"].Value, L["WizardStep4"].Value
        };
    }
    @for (int si = 1; si <= 4; si++)
    {
        <div class="d-flex flex-column align-items-center">
            <div class="wz-circle upcoming" id="wz-c-@si">@si</div>
            <span class="wz-step-label text-muted mt-1" id="wz-l-@si">@stepLabels[si - 1]</span>
        </div>
        if (si < 4) { <div class="wz-conn upcoming" id="wz-conn-@si"></div> }
    }
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="wz-form">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingCoverImageUrl" />

    <div id="step-1" class="wz-step">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-info-circle me-2 text-primary"></i>@L["BasicInfo"]
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" id="f-title" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                        <select asp-for="CategoryId" asp-items="@Model.Categories"
                                class="form-select" id="f-cat">
                            <option value="">— @L["SelectCategory"] —</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            @L["Venue"]
                            <span class="fw-normal text-muted small">(@L["Optional"])</span>
                        </label>
                        <select asp-for="VenueId" asp-items="@Model.Venues" class="form-select">
                            <option value="">— @L["SelectVenue"] —</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-semibold"></label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" id="f-start"
                               value="@(Model.StartDate == default ? "" : Model.StartDate.ToString("yyyy-MM-ddTHH:mm"))" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-semibold"></label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" id="f-end"
                               value="@(Model.EndDate == default ? "" : Model.EndDate.ToString("yyyy-MM-ddTHH:mm"))" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="HasTicketing" class="form-check-input" role="switch"
                                   id="HasTicketing" onchange="onTicketingToggle()" />
                            <label asp-for="HasTicketing" class="form-check-label fw-semibold">@L["HasTicketing"]</label>
                            <div class="form-text">@L["HasTicketingHint"]</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-end align-items-center">
            <button type="button" class="ke-btn ke-btn-primary" onclick="wzNext()">
                @L["Continue"] <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <div id="step-2" class="wz-step d-none">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-text-paragraph me-2 text-primary"></i>@L["WizardStep2"]
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="8" id="f-desc"></textarea>
                    <div class="form-text">@L["SupportsBasicFormatting"]</div>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">@L["ShortDescription"]</label>
                    <input asp-for="ShortDescription" class="form-control" id="f-short"
                           maxlength="500" oninput="wzCounter(this,'cnt-short',500)" />
                    <div class="d-flex justify-content-between mt-1">
                        <span class="form-text">@L["ShortDescriptionHint"]</span>
                        <small class="text-muted" id="cnt-short" data-template="@L["CharsRemaining"].Value"></small>
                    </div>
                    <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            @L["Capacity"]
                            <span class="fw-normal text-muted small">(@L["Optional"])</span>
                        </label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MinAge" class="form-label fw-semibold"></label>
                        <input asp-for="MinAge" class="form-control" type="number" min="0" max="120" />
                        <span asp-validation-for="MinAge" class="text-danger small"></span>
                    </div>
                </div>

                @if (Model.Tags != null && Model.Tags.Any())
                {
                    <div class="mt-3">
                        <label class="form-label fw-semibold">@L["Tags"]</label>
                        <div class="d-flex flex-wrap gap-2" id="tag-chips">
                            @foreach (var tag in Model.Tags)
                            {
                                var tagId = int.TryParse(tag.Value, out var tid) ? tid : 0;
                                var isSelected = Model.SelectedTagIds.Contains(tagId);
                                <button type="button"
                                        class="tag-chip @(isSelected ? "tag-chip-selected" : "")"
                                        onclick="wzToggleTag(this,'@tag.Value')">
                                    <i class="bi bi-tag" style="font-size:11px;"></i>
                                    @tag.Text
                                </button>
                                <input type="checkbox" name="SelectedTagIds" value="@tag.Value"
                                       class="d-none" id="tag-cb-@tag.Value"
                                       @(isSelected ? "checked" : "") />
                            }
                        </div>
                    </div>
                }

                <div class="mt-3">
                    <div class="form-check form-switch">
                        <input asp-for="IsAccessible" class="form-check-input" role="switch" />
                        <label asp-for="IsAccessible" class="form-check-label fw-semibold">@L["Accessibility"]</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <button type="button" class="ke-btn ke-btn-ghost" onclick="wzPrev()">
                <i class="bi bi-arrow-left"></i>@L["Back"]
            </button>
            <button type="button" class="ke-btn ke-btn-primary" onclick="wzNext()">
                @L["Continue"] <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <div id="step-3" class="wz-step d-none">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-ticket me-2 text-primary"></i>@L["TicketTypes"]
            </div>
            <div class="card-body">
                <div id="free-notice" class="alert alert-info d-none mb-3">
                    <i class="bi bi-info-circle me-2"></i>@L["FreeEventSkipsTickets"]
                </div>
                <div id="tt-section">
                    <div id="tt-rows">
                        @{int ttIdx = 0;}
                        @foreach (var tt in Model.TicketTypeInputs)
                        {
                            <div class="row g-2 mb-2 align-items-end wz-tt-row">
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold small">@L["TicketName"]</label>
                                    <input name="TicketTypeInputs[@ttIdx].Name"
                                           class="form-control form-control-sm" value="@tt.Name" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold small">@L["Quantity"]</label>
                                    <input name="TicketTypeInputs[@ttIdx].Quantity"
                                           class="form-control form-control-sm"
                                           type="number" min="1" value="@tt.Quantity" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold small">
                                        @L["Description"]
                                        <span class="fw-normal text-muted">(opt.)</span>
                                    </label>
                                    <input name="TicketTypeInputs[@ttIdx].Description"
                                           class="form-control form-control-sm" value="@tt.Description" />
                                </div>
                                <div class="col-md-1 d-flex align-items-end pb-1">
                                    <button type="button" class="ke-btn ke-btn-danger ke-btn-sm w-100"
                                            onclick="this.closest('.wz-tt-row').remove()"
                                            title="@L["Remove"]">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            </div>
                            ttIdx++;
                        }
                    </div>
                    <button type="button" id="wz-add-ticket-btn" class="ke-btn ke-btn-sm mt-1"
                            onclick="wzAddTicket()"
                            data-name-label="@L["TicketName"].Value"
                            data-qty-label="@L["Quantity"].Value"
                            data-desc-label="@L["Description"].Value"
                            data-remove-title="@L["Remove"].Value">
                        <i class="bi bi-plus-lg"></i>@L["AddTicketType"]
                    </button>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <button type="button" class="ke-btn ke-btn-ghost" onclick="wzPrev()">
                <i class="bi bi-arrow-left"></i>@L["Back"]
            </button>
            <button type="button" class="ke-btn ke-btn-primary" onclick="wzNext()">
                @L["Continue"] <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <div id="step-4" class="wz-step d-none">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-images me-2 text-primary"></i>@L["WizardStep4"]
            </div>
            <div class="card-body">

                <label class="form-label fw-semibold">@L["CoverImage"]</label>
                <div class="drop-zone d-flex flex-column align-items-center justify-content-center p-4 mb-2"
                     id="cover-dz"
                     onclick="document.getElementById('CoverImage').click()"
                     ondragover="event.preventDefault();this.classList.add('dragover')"
                     ondragleave="this.classList.remove('dragover')"
                     ondrop="wzDrop(event,'CoverImage','cover-prev',false)">
                    <div id="cover-prev" class="w-100 text-center">
                        @if (!string.IsNullOrEmpty(Model.ExistingCoverImageUrl))
                        {
                            <img src="@Model.ExistingCoverImageUrl" class="rounded"
                                 style="max-height:160px;max-width:100%;object-fit:cover" alt="Cover" />
                            <p class="text-muted small mt-2 mb-0">
                                <i class="bi bi-arrow-repeat me-1"></i>@L["ChangeImage"]
                            </p>
                        }
                        else
                        {
                            <i class="bi bi-cloud-upload text-muted" style="font-size:2.8rem"></i>
                            <p class="text-muted mt-2 mb-0 small">@L["DropImageOrClick"]</p>
                        }
                    </div>
                </div>
                <input asp-for="CoverImage" type="file" accept="image/*" class="d-none"
                       onchange="wzPreview(this,'cover-prev',false)" />

                <hr class="my-4" />

                @if (Model.ExistingImages.Any())
                {
                    <label class="form-label fw-semibold">@L["EventImages"]</label>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var img in Model.ExistingImages)
                        {
                            <div class="thumb-wrap">
                                <img src="@img.ImageUrl" alt="@img.Caption" />
                                <button type="button"
                                        class="ke-btn ke-btn-danger thumb-del"
                                        onclick="keConfirm('@L["ConfirmDeleteImage"].Value', '', '@L["Delete"].Value', function(){ document.getElementById('del-@img.Id').submit(); })"
                                        title="@L["DeleteImage"]">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-3">
                        <i class="bi bi-images me-1"></i>@L["NoImages"]
                    </p>
                }

                <label class="form-label fw-semibold">@L["AdditionalImages"]</label>
                <div class="drop-zone d-flex flex-column align-items-center justify-content-center p-3 mb-2"
                     id="extra-dz"
                     onclick="document.getElementById('extra-inp').click()"
                     ondragover="event.preventDefault();this.classList.add('dragover')"
                     ondragleave="this.classList.remove('dragover')"
                     ondrop="wzDropExtra(event)">
                    <div id="extra-prev" class="d-flex flex-wrap gap-2 justify-content-center w-100">
                        <div class="text-center text-muted">
                            <i class="bi bi-images" style="font-size:2rem"></i>
                            <p class="mb-0 small">@L["DropImageOrClick"]</p>
                        </div>
                    </div>
                </div>
                <input type="file" id="extra-inp" name="images" form="upload-form"
                       accept="image/jpeg,image/png,image/webp" multiple class="d-none"
                       onchange="wzPreview(this,'extra-prev',true)" />
                <div class="form-text">@L["ImageUploadHint"]</div>
                <button type="submit" form="upload-form" class="ke-btn ke-btn-sm mt-2">
                    <i class="bi bi-cloud-upload"></i>@L["UploadImages"]
                </button>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <button type="button" class="ke-btn ke-btn-ghost" onclick="wzPrev()">
                <i class="bi bi-arrow-left"></i>@L["Back"]
            </button>
            @if (Model.Status == EventStatus.Published)
            {
                <button type="submit" class="ke-btn ke-btn-primary ke-btn-lg">
                    <i class="bi bi-check-circle"></i>@L["UpdateEvent"]
                </button>
            }
            else
            {
                <button type="submit" class="ke-btn ke-btn-success ke-btn-lg">
                    <i class="bi bi-floppy"></i>@L["SaveChanges"]
                </button>
            }
        </div>
    </div>

</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script src="~/js/pages/event-edit.js" asp-append-version="true"></script>
}
