@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    ViewData["Title"] = L["CreateEvent"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <div class="card border-0 shadow-sm rounded-4 p-5">
            <i class="bi bi-calendar-plus fs-1 text-muted mb-3"></i>
            <h2 class="h4 fw-semibold mb-2">@L["CreateEvent"]</h2>
            <p class="text-muted mb-4">@L["NotOrganizerMessage"]</p>
            <a asp-controller="Profile" asp-action="RequestOrganizer"
               class="ke-btn ke-btn-primary">
                <i class="bi bi-person-check me-1"></i>@L["NotOrganizerLink"]
            </a>
            <div class="mt-3">
                <a asp-controller="Event" asp-action="Index" class="text-muted small">
                    @L["BackToEvents"]
                </a>
            </div>
        </div>
    </div>
</div>
