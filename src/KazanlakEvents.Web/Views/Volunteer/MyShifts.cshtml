@model MyShiftsViewModel
@using KazanlakEvents.Domain.Enums
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{ ViewData["Title"] = L["MyVolunteerShifts"].Value; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-person-raised-hand me-2"></i>@L["MyVolunteerShifts"]</h4>
    <a asp-controller="Profile" asp-action="Index" class="ke-btn ke-btn-ghost ke-btn-sm">
        <i class="bi bi-person"></i>@L["Profile"]
    </a>
</div>

@if (!Model.Signups.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-raised-hand fs-1 d-block mb-3 opacity-25"></i>
        <p class="mb-2">@L["NoVolunteerSignups"]</p>
        <a asp-controller="Event" asp-action="Index" class="ke-btn ke-btn-primary ke-btn-sm mt-1">
            <i class="bi bi-calendar-event me-2"></i>@L["BrowseVolunteerEvents"]
        </a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@L["Event"]</th>
                        <th>@L["Task"]</th>
                        <th>@L["ShiftTime"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["HoursLogged"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Signups)
                    {
                        var (badgeClass, badgeText) = s.Status switch
                        {
                            VolunteerSignupStatus.Registered => ("text-bg-warning",  L["VolunteerStatusRegistered"].Value),
                            VolunteerSignupStatus.Confirmed  => ("text-bg-primary",  L["VolunteerStatusConfirmed"].Value),
                            VolunteerSignupStatus.Completed  => ("text-bg-success",  L["VolunteerStatusCompleted"].Value),
                            VolunteerSignupStatus.NoShow     => ("text-bg-danger",   L["VolunteerStatusNoShow"].Value),
                            _                                => ("text-bg-secondary", s.Status.ToString())
                        };
                        <tr>
                            <td>
                                <a asp-controller="Event" asp-action="Details"
                                   asp-route-slug="@s.EventSlug"
                                   class="text-decoration-none fw-semibold small">
                                    @s.EventTitle
                                </a>
                            </td>
                            <td class="small">@s.TaskName</td>
                            <td class="small text-nowrap text-muted">
                                @s.ShiftStart.ToString("dd.MM HH:mm") &ndash; @s.ShiftEnd.ToString("HH:mm")
                            </td>
                            <td>
                                <span class="badge @badgeClass">@badgeText</span>
                            </td>
                            <td class="small text-muted">
                                @(s.HoursLogged.HasValue ? s.HoursLogged.Value.ToString("F1") + "h" : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
