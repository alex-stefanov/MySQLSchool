@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "bg";
    var isHomePage     = ViewData["IsHomePage"] as bool? == true;
    var ctrl           = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act            = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool IsActive(string c, string? a = null) =>
        ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) &&
        (a == null || act.Equals(a, StringComparison.OrdinalIgnoreCase));

    var initials = User.FindFirst("Initials")?.Value ?? "U";

    var announcementText = ViewData["AnnouncementEvent"] as string;
    var announcementLink = ViewData["AnnouncementLink"] as string ?? "#";
    var hideNavFooter   = ViewData["HideNavFooter"] as bool? == true;
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KazanlakEvents</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/event-card.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <meta property="og:site_name" content="KazanlakEvents" />
    <meta property="og:type" content="@(ViewData["OgType"] ?? "website")" />
    <meta property="og:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"])" />
    <meta property="og:description" content="@(ViewData["OgDescription"] ?? "Discover events in Kazanlak")" />
    <meta property="og:image" content="@(ViewData["OgImage"] ?? "/images/og-default.png")" />
    <meta property="og:url" content="@Context.Request.GetDisplayUrl()" />
    <meta name="twitter:card" content="summary_large_image" />
</head>
<body>
    <a href="#main-content" class="visually-hidden-focusable">@L["SkipToMainContent"]</a>

    @if (!hideNavFooter)
    {
    <header id="ke-header" class="@(isHomePage ? "nav-homepage" : "nav-standard")">

        <nav class="ke-nav-inner" aria-label="Main navigation">
            <a class="ke-brand" asp-controller="Home" asp-action="Index">
                <span class="ke-brand-icon" aria-hidden="true"><i class="bi bi-calendar-event"></i></span>
                <span class="ke-brand-text">KazanlakEvents</span>
            </a>

            <div class="ke-nav-links">
                <a class="ke-nav-link @(IsActive("Event") && !IsActive("Event","Calendar") ? "active" : "")"
                   asp-controller="Event" asp-action="Index">@L["Events"]</a>
                <a class="ke-nav-link @(IsActive("Event","Calendar") ? "active" : "")"
                   asp-controller="Event" asp-action="Calendar">@L["Calendar"]</a>
                <a class="ke-nav-link @(IsActive("Blog") ? "active" : "")"
                   asp-controller="Blog" asp-action="Index">@L["Blog"]</a>
                <a class="ke-nav-link @(IsActive("Home","About") ? "active" : "")"
                   asp-controller="Home" asp-action="About">@L["About"]</a>
            </div>

            <button class="ke-hamburger ms-auto" id="ke-hamburger" aria-label="Menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>

            <div class="ke-nav-right">
                <div class="ke-lang">
                    <form asp-controller="Home" asp-action="SetLanguage" method="post" class="form-display-contents">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="culture" value="bg" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" class="ke-lang-btn @(currentCulture == "bg" ? "active-lang" : "")">BG</button>
                    </form>
                    <form asp-controller="Home" asp-action="SetLanguage" method="post" class="form-display-contents">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="culture" value="en" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" class="ke-lang-btn @(currentCulture == "en" ? "active-lang" : "")">EN</button>
                    </form>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="ke-icon-btn" asp-controller="Notification" asp-action="Index"
                       aria-label="@L["Notifications"].Value" title="@L["Notifications"].Value">
                        <i class="bi bi-bell" aria-hidden="true"></i>
                        <span id="notif-dot" class="ke-notif-dot" aria-hidden="true"></span>
                    </a>

                    <div class="ke-dropdown">
                        <button class="ke-avatar" id="ke-avatar-btn"
                                aria-haspopup="true" aria-expanded="false" aria-label="User menu">@initials</button>
                        <div class="ke-dropdown-menu" id="ke-avatar-menu" role="menu">
                            <div class="ke-dropdown-user-name">@User.Identity.Name</div>
                            <div class="ke-dropdown-divider"></div>

                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Moderator"))
                            {
                                <a class="ke-dropdown-item" asp-controller="Admin" asp-action="Dashboard" role="menuitem">
                                    <i class="bi bi-grid-1x2"></i>@L["AdminDashboard"]
                                </a>
                                <div class="ke-dropdown-divider"></div>
                            }
                            else if (User.IsInRole("Organizer"))
                            {
                                <div class="ke-dropdown-label">@L["Organizer"]</div>
                                <a class="ke-dropdown-item" asp-controller="Event" asp-action="MyEvents" role="menuitem">
                                    <i class="bi bi-calendar2-event"></i>@L["ManageEvents"]
                                </a>
                                <a class="ke-dropdown-item" asp-controller="Event" asp-action="Create" role="menuitem">
                                    <i class="bi bi-plus-circle"></i>@L["CreateEvent"]
                                </a>
                                <div class="ke-dropdown-divider"></div>
                            }

                            @if (User.IsInRole("BlogAuthor") && !User.IsInRole("Admin") && !User.IsInRole("SuperAdmin") && !User.IsInRole("Moderator"))
                            {
                                <div class="ke-dropdown-label">@L["Blog"]</div>
                                <a class="ke-dropdown-item" asp-controller="Blog" asp-action="MyPosts" role="menuitem">
                                    <i class="bi bi-file-text"></i>@L["MyBlogPosts"]
                                </a>
                                <a class="ke-dropdown-item" asp-controller="Blog" asp-action="Create" role="menuitem">
                                    <i class="bi bi-plus-circle"></i>@L["CreatePost"]
                                </a>
                                <div class="ke-dropdown-divider"></div>
                            }
                            else if (User.Identity!.IsAuthenticated
                                     && !User.IsInRole("BlogAuthor")
                                     && !User.IsInRole("Admin")
                                     && !User.IsInRole("SuperAdmin")
                                     && !User.IsInRole("Moderator"))
                            {
                                <a class="ke-dropdown-item" asp-controller="Blog" asp-action="RequestAuthor" role="menuitem">
                                    <i class="bi bi-pencil-square"></i>@L["BecomeBlogAuthor"]
                                </a>
                                <div class="ke-dropdown-divider"></div>
                            }

                            <a class="ke-dropdown-item" asp-controller="Profile" asp-action="Index" role="menuitem">
                                <i class="bi bi-person"></i>@L["MyProfile"]
                            </a>

                            <div class="ke-dropdown-divider"></div>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="ke-dropdown-item" role="menuitem">
                                    <i class="bi bi-box-arrow-right"></i>@L["Logout"]
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a class="ke-btn-login" asp-controller="Account" asp-action="Login">@L["Login"]</a>
                    <a class="ke-btn-signup" asp-controller="Account" asp-action="Register">@L["Register"]</a>
                }
            </div>
        </nav>

        <nav class="ke-mobile-nav" id="ke-mobile-nav" aria-label="Mobile navigation">
            <a class="ke-nav-link @(IsActive("Event") && !IsActive("Event","Calendar") ? "active" : "")"
               asp-controller="Event" asp-action="Index">@L["Events"]</a>
            <a class="ke-nav-link @(IsActive("Event","Calendar") ? "active" : "")"
               asp-controller="Event" asp-action="Calendar">@L["Calendar"]</a>
            <a class="ke-nav-link @(IsActive("Blog") ? "active" : "")"
               asp-controller="Blog" asp-action="Index">@L["Blog"]</a>
            <a class="ke-nav-link @(IsActive("Home","About") ? "active" : "")"
               asp-controller="Home" asp-action="About">@L["About"]</a>
        </nav>
    </header>
    }

    @if (hideNavFooter)
    {
    <main id="main-content">
        @RenderBody()
    </main>
    }
    else
    {
    <main id="main-content" class="container py-4">
        @RenderBody()
    </main>
    }

    @if (!hideNavFooter)
    {
    <footer class="ke-footer">
        <div class="ke-footer-inner">
            <div class="row g-5">

                <div class="col-lg-4 col-md-6">
                    <a class="ke-brand ke-footer-brand" asp-controller="Home" asp-action="Index">
                        <span class="ke-brand-icon" aria-hidden="true"><i class="bi bi-calendar-event"></i></span>
                        <span class="ke-brand-text">KazanlakEvents</span>
                    </a>
                    <p class="ke-footer-brand-desc">@L["FooterDescription"]</p>
                    <div class="d-flex gap-2">
                        <a href="https://www.tiktok.com/@@rose_events_bg?is_from_webapp=1&sender_device=pc" class="ke-social-btn" aria-label="TikTok"><i class="bi bi-tiktok" aria-hidden="true"></i></a>
                        <a href="https://www.instagram.com/_rose.events_/" class="ke-social-btn" aria-label="Instagram"><i class="bi bi-instagram" aria-hidden="true"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-3 col-6">
                    <div class="ke-footer-heading">@L["FooterDiscover"]</div>
                    <a class="ke-footer-link" asp-controller="Event" asp-action="Index">@L["AllEvents"]</a>
                    <a class="ke-footer-link" asp-controller="Event" asp-action="Calendar">@L["Calendar"]</a>
                    <a class="ke-footer-link" asp-controller="Blog" asp-action="Index">@L["Blog"]</a>
                </div>

                <div class="col-lg-3 col-md-3 col-6">
                    <div class="ke-footer-heading">@L["FooterGetInvolved"]</div>
                    <a class="ke-footer-link" asp-controller="Event" asp-action="Index" asp-route-hasVolunteerTasks="true">@L["Volunteer"]</a>
                    <a class="ke-footer-link" asp-controller="Event" asp-action="Create">@L["OrganizeAnEvent"]</a>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="Contact">@L["BecomeASponsor"]</a>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="ke-footer-heading">@L["About"]</div>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="About">@L["AboutUs"]</a>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="Contact">@L["ContactUs"]</a>
                    <a class="ke-footer-link" asp-controller="Sponsor" asp-action="Index">@L["OurSponsors"]</a>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="Privacy">@L["PrivacyPolicy"]</a>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="Terms">@L["TermsOfService"]</a>
                    <a class="ke-footer-link" asp-controller="Home" asp-action="ApiDocs">@L["ApiDocs"]</a>
                </div>
            </div>

            <div class="ke-footer-bottom">
                <span>&copy; @DateTime.Now.Year Association For Youth. @L["AllRightsReserved"]</span>
                <span>@L["KazanlakBulgaria"]</span>
            </div>
        </div>
    </footer>
    }

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div id="toast-notification" class="ke-toast @(TempData["Error"] != null ? "ke-toast-error" : "ke-toast-success")">
            <span class="ke-toast-icon">@(TempData["Error"] != null ? "✕" : "✓")</span>
            <span class="ke-toast-text">@(TempData["Success"] ?? TempData["Error"])</span>
            <button class="ke-toast-close">×</button>
        </div>
    }

    <div id="ke-confirm-modal">
        <div class="ke-confirm-dialog">
            <div class="ke-confirm-icon" id="ke-confirm-icon">!</div>
            <h3 class="ke-confirm-title" id="ke-confirm-title"></h3>
            <p class="ke-confirm-text" id="ke-confirm-text"></p>
            <div class="ke-confirm-actions">
                <button class="ke-btn" data-confirm-cancel>@L["Cancel"]</button>
                <button id="ke-confirm-action" class="ke-btn ke-btn-danger">@L["Delete"]</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
