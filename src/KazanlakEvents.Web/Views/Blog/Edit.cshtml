@model BlogPostEditViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    var isBlogAuthorOnly = User.IsInRole("BlogAuthor")
        && !User.IsInRole("Admin") && !User.IsInRole("SuperAdmin") && !User.IsInRole("Moderator");
    Layout = isBlogAuthorOnly ? "_Layout" : "_AdminLayout";
    if (!isBlogAuthorOnly) ViewData["AdminPage"] = "Blog";
    ViewData["Title"] = L["EditPost"].Value;
}

@if (isBlogAuthorOnly)
{
    <div style="max-width:800px;margin:0 auto;padding-top:32px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 style="font-size:24px;font-weight:600;margin:0;">@L["EditPost"]</h1>
            <a asp-action="MyPosts" class="ke-btn ke-btn-ghost ke-btn-sm">
                <i class="bi bi-arrow-left me-1"></i>@L["MyBlogPosts"]
            </a>
        </div>
        <div class="card" style="border:1px solid var(--ke-border);background:var(--ke-surface);">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-semibold small">@L["Title"] <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="CategoryId" class="form-label fw-semibold small">@L["Category"]</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                    </div>
                    <div class="mb-4">
                        <label asp-for="CoverImageUrl" class="form-label fw-semibold small">@L["CoverImageUrl"]</label>
                        <input asp-for="CoverImageUrl" class="form-control" placeholder="https://..." />
                    </div>
                    <div class="mb-4">
                        <label asp-for="Excerpt" class="form-label fw-semibold small">@L["Excerpt"]</label>
                        <textarea asp-for="Excerpt" class="form-control" rows="2"
                                  placeholder="@L["ExcerptPlaceholder"].Value"></textarea>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-semibold small">@L["Content"] <span class="text-danger">*</span></label>
                        <textarea asp-for="Content" class="form-control" rows="14"
                                  placeholder="@L["ContentPlaceholder"].Value"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="ke-btn ke-btn-primary">
                            <i class="bi bi-floppy me-1"></i>@L["SaveChanges"]
                        </button>
                        <a asp-action="MyPosts" class="ke-btn ke-btn-ghost">@L["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">@L["EditPost"]</h1>
        <a asp-action="Manage" class="ke-btn ke-btn-ghost ke-btn-sm">
            <i class="bi bi-arrow-left"></i>@L["BackToManage"]
        </a>
    </div>
    <form asp-action="Edit" method="post" style="max-width:640px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
        <div class="mb-4">
            <label asp-for="Title" class="form-label fw-semibold small">@L["Title"] <span class="text-danger">*</span></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="CategoryId" class="form-label fw-semibold small">@L["Category"]</label>
            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
        </div>
        <div class="mb-4">
            <label asp-for="CoverImageUrl" class="form-label fw-semibold small">@L["CoverImageUrl"]</label>
            <input asp-for="CoverImageUrl" class="form-control" placeholder="https://..." />
        </div>
        <div class="mb-4">
            <label asp-for="Excerpt" class="form-label fw-semibold small">@L["Excerpt"]</label>
            <textarea asp-for="Excerpt" class="form-control" rows="2"
                      placeholder="@L["ExcerptPlaceholder"].Value"></textarea>
        </div>
        <div class="mb-4">
            <label asp-for="Content" class="form-label fw-semibold small">@L["Content"] <span class="text-danger">*</span></label>
            <textarea asp-for="Content" class="form-control" rows="14"
                      placeholder="@L["ContentPlaceholder"].Value"></textarea>
            <span asp-validation-for="Content" class="text-danger small"></span>
        </div>
        <div class="mb-4 d-flex gap-4">
            <div class="form-check form-switch">
                <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                <label asp-for="IsPublished" class="form-check-label small">@L["Published"]</label>
            </div>
            <div class="form-check form-switch">
                <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                <label asp-for="IsFeatured" class="form-check-label small">@L["Featured"]</label>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="ke-btn ke-btn-primary">
                <i class="bi bi-floppy"></i>@L["SaveChanges"]
            </button>
            <a asp-action="Manage" class="ke-btn ke-btn-ghost">@L["Cancel"]</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
