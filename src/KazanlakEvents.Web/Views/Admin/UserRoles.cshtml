@model UserRolesViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    Layout = "_AdminLayout";
    ViewData["AdminPage"] = "UserRoles";
    ViewData["AdminPageTitle"] = L["UserRoles"].Value;
}

<div class="mb-4">
    <form method="get" asp-action="UserRoles" asp-controller="Admin" class="d-flex gap-2" style="max-width:480px;">
        <input type="text" name="search" value="@Model.SearchQuery" class="form-control"
               placeholder="@L["SearchByUser"]" style="border-radius:8px;font-size:14px;" />
        <button type="submit" class="ke-btn ke-btn-primary" style="white-space:nowrap;">
            <i class="bi bi-search me-1"></i>@L["Search"]
        </button>
    </form>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
{
    if (!Model.Users.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-person-x" style="font-size:40px;opacity:0.4;"></i>
            <div class="mt-2">@L["NoResultsFound"]</div>
        </div>
    }
    else
    {
        <div class="card" style="border-radius:14px;border:0.5px solid var(--ke-border)">
            <div class="card-body p-0">
                <table class="table mb-0" style="font-size:13px;">
                    <thead>
                        <tr style="background:var(--ke-surface-secondary);font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--ke-text-muted)">
                            <th style="padding:10px 18px;font-weight:500">@L["User"]</th>
                            <th style="padding:10px 12px;font-weight:500">@L["CurrentRoles"]</th>
                            <th style="padding:10px 18px;font-weight:500;text-align:right">@L["AddRole"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr style="border-bottom:0.5px solid var(--ke-border)">
                                <td style="padding:12px 18px;vertical-align:middle">
                                    <div class="d-flex align-items-center gap-3">
                                        <span style="width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;font-size:13px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">@user.Initials</span>
                                        <div>
                                            <div class="fw-medium">@user.UserName</div>
                                            <div style="font-size:12px;color:var(--ke-text-muted)">@user.Email</div>
                                        </div>
                                    </div>
                                </td>

                                <td style="padding:12px;vertical-align:middle">
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var role in user.Roles.OrderBy(r => r))
                                        {
                                            <span class="d-inline-flex align-items-center gap-1 px-2 py-1 rounded"
                                                  style="font-size:11px;font-weight:500;background:var(--ke-surface-secondary);border:0.5px solid var(--ke-border);">
                                                @role
                                                <form asp-action="RemoveRole" asp-controller="Admin" method="post" style="display:inline;margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <input type="hidden" name="role" value="@role" />
                                                    <input type="hidden" name="search" value="@Model.SearchQuery" />
                                                    <button type="submit" style="border:none;background:none;padding:0;cursor:pointer;line-height:1;color:var(--ke-text-muted);font-size:13px;"
                                                            title="@L["RemoveRole"]"
                                                            onclick="return confirm('@L["AreYouSure"]')">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </form>
                                            </span>
                                        }
                                        @if (!user.Roles.Any())
                                        {
                                            <span style="font-size:12px;color:var(--ke-text-muted)">—</span>
                                        }
                                    </div>
                                </td>

                                <td style="padding:12px 18px;vertical-align:middle;text-align:right">
                                    <form asp-action="AssignRole" asp-controller="Admin" method="post"
                                          class="d-flex gap-2 justify-content-end">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="search" value="@Model.SearchQuery" />
                                        <select name="role" class="form-select form-select-sm"
                                                style="width:auto;font-size:12px;border-radius:8px;min-width:130px;">
                                            <option value="">@L["SelectRole"]</option>
                                            @foreach (var role in Model.AvailableRoles)
                                            {
                                                if (user.Roles.Contains(role))
                                                {
                                                    <option value="@role" disabled>@role ✓</option>
                                                }
                                                else
                                                {
                                                    <option value="@role">@role</option>
                                                }
                                            }
                                        </select>
                                        <button type="submit" class="ke-btn ke-btn-primary" style="font-size:12px;padding:4px 10px;white-space:nowrap;">
                                            <i class="bi bi-plus-lg me-1"></i>@L["AddRole"]
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <div class="text-center py-5 text-muted" style="max-width:380px;margin:0 auto;">
        <i class="bi bi-person-badge" style="font-size:48px;opacity:0.3;"></i>
        <div class="mt-3 fw-medium">@L["SearchByUser"]</div>
    </div>
}
