@model KazanlakEvents.Web.ViewModels.Admin.AdminEventsViewModel
@using KazanlakEvents.Domain.Enums
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    Layout = "_AdminLayout";
    ViewData["AdminPage"]      = "Events";
    ViewData["AdminPageTitle"] = L["Events"].Value;

    (string? value, string label)[] tabs =
    {
        (null,       L["All"].Value),
        ("pending",  L["PendingApproval"].Value),
        ("modified", L["RecentlyModifiedTab"].Value)
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        @L["Events"]
        @if (Model.TotalCount > 0)
        {
            <span class="badge ms-2 align-middle"
                  style="background:rgba(99,102,241,.12);color:#6366f1;font-size:.7rem;font-weight:600;border-radius:20px;padding:4px 10px;">
                @Model.TotalCount
            </span>
        }
    </h1>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    @foreach (var (value, label) in tabs)
    {
        var isActive = Model.Filter == value;
        <a asp-action="Events" asp-route-filter="@value"
           class="badge rounded-pill text-decoration-none px-3 py-2"
           style="@(isActive
               ? "background:var(--ke-primary);color:#fff;font-weight:600;"
               : "background:var(--ke-surface-secondary);color:var(--ke-text-secondary);font-weight:500;border:1px solid var(--ke-border);")">
            @label
        </a>
    }
</div>

@if (!Model.Events.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-calendar-check fs-1 d-block mb-3" style="color:#10b981;opacity:.6;"></i>
        <p class="mb-0 fw-semibold" style="color:var(--ke-text-secondary);">@L["NoPendingEvents"]</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var ev in Model.Events)
        {
            <div class="card" style="border:1px solid var(--ke-border);background:var(--ke-surface);">
                <div class="card-body p-3">
                    <div class="d-flex gap-3 align-items-start">

                        @if (!string.IsNullOrEmpty(ev.CoverImageUrl))
                        {
                            <img src="@ev.CoverImageUrl" alt=""
                                 style="width:72px;height:72px;object-fit:cover;border-radius:10px;flex-shrink:0;" />
                        }
                        else
                        {
                            <div style="width:72px;height:72px;border-radius:10px;background:var(--ke-surface-secondary);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-calendar-event" style="font-size:24px;color:var(--ke-text-muted);"></i>
                            </div>
                        }

                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="fw-semibold" style="color:var(--ke-text);font-size:.95rem;">@ev.Title</span>
                                @switch (ev.Status)
                                {
                                    case EventStatus.PendingApproval:
                                        <span class="badge rounded-pill" style="background:rgba(245,158,11,.12);color:#d97706;font-weight:500;font-size:.7rem;">
                                            <i class="bi bi-hourglass-split me-1"></i>@L["PendingApproval"]
                                        </span>
                                        break;
                                    case EventStatus.Approved:
                                        <span class="badge rounded-pill" style="background:rgba(16,185,129,.12);color:#10b981;font-weight:500;font-size:.7rem;">
                                            <i class="bi bi-check-circle me-1"></i>@L["Approved"]
                                        </span>
                                        break;
                                    case EventStatus.Rejected:
                                        <span class="badge rounded-pill" style="background:rgba(239,68,68,.12);color:#ef4444;font-weight:500;font-size:.7rem;">
                                            <i class="bi bi-x-circle me-1"></i>@L["Rejected"]
                                        </span>
                                        break;
                                    case EventStatus.Published:
                                        <span class="badge rounded-pill" style="background:rgba(99,102,241,.12);color:#6366f1;font-weight:500;font-size:.7rem;">
                                            <i class="bi bi-globe me-1"></i>@L["Published"]
                                        </span>
                                        break;
                                    default:
                                        <span class="badge rounded-pill" style="background:var(--ke-surface-secondary);color:var(--ke-text-secondary);font-weight:500;font-size:.7rem;border:1px solid var(--ke-border);">
                                            @ev.Status.ToString()
                                        </span>
                                        break;
                                }
                            </div>
                            <div class="d-flex flex-wrap gap-2 align-items-center small" style="color:var(--ke-text-secondary);">
                                @if (!string.IsNullOrEmpty(ev.OrganizerName))
                                {
                                    <span><i class="bi bi-person me-1"></i>@ev.OrganizerName</span>
                                    <span style="color:var(--ke-border);">·</span>
                                }
                                <span><i class="bi bi-clock me-1"></i>@ev.SubmittedAt.ToString("dd.MM.yyyy")</span>
                                @if (!string.IsNullOrEmpty(ev.CategoryName))
                                {
                                    <span style="color:var(--ke-border);">·</span>
                                    <span class="badge rounded-pill"
                                          style="background:rgba(99,102,241,.12);color:#6366f1;font-weight:500;">
                                        @ev.CategoryName
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-shrink-0 align-items-start">
                            <a asp-controller="Event" asp-action="Details" asp-route-slug="@ev.Slug"
                               class="ke-btn ke-btn-ghost ke-btn-sm" target="_blank" title="@L["View"].Value">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (ev.Status == EventStatus.PendingApproval)
                            {
                                <form asp-action="ApproveEvent" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@ev.Id" />
                                    <button type="submit" class="ke-btn ke-btn-success ke-btn-sm">
                                        <i class="bi bi-check-lg"></i>@L["Approve"]
                                    </button>
                                </form>
                                <button type="button" class="ke-btn ke-btn-danger ke-btn-sm"
                                        data-bs-toggle="modal" data-bs-target="#rejectModal-@ev.Id">
                                    <i class="bi bi-x-lg"></i>@L["Reject"]
                                </button>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <form asp-action="DeleteEvent" method="post" class="d-inline" id="del-ev-@ev.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@ev.Id" />
                                    <button type="button" class="ke-btn ke-btn-danger ke-btn-sm"
                                            style="width:32px;height:32px;padding:0;"
                                            onclick="keConfirm('@L["ConfirmDelete"].Value','','@L["Delete"].Value',function(){ document.getElementById('del-ev-@ev.Id').submit(); })"
                                            title="@L["Delete"].Value">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Events" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Events" asp-route-filter="@Model.Filter" asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Events" asp-route-filter="@Model.Filter" asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }

    @foreach (var ev in Model.Events.Where(e => e.Status == EventStatus.PendingApproval))
    {
        <div class="modal fade" id="rejectModal-@ev.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" style="background:var(--ke-surface);border:1px solid var(--ke-border);">
                    <div class="modal-header" style="background:rgba(239,68,68,.08);border-bottom:1px solid var(--ke-border);">
                        <h5 class="modal-title fw-semibold" style="color:#ef4444;">
                            <i class="bi bi-x-circle me-2"></i>@L["RejectConfirm"]
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="RejectEvent" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventId" value="@ev.Id" />
                        <div class="modal-body">
                            <p class="fw-semibold mb-3" style="color:var(--ke-text);">@ev.Title</p>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">@L["RejectReason"]</label>
                                <textarea name="reason" class="form-control" rows="4"
                                          placeholder="@L["RejectReasonPlaceholder"].Value" required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer" style="border-top:1px solid var(--ke-border);">
                            <button type="button" class="ke-btn ke-btn-ghost ke-btn-sm" data-bs-dismiss="modal">
                                @L["Cancel"]
                            </button>
                            <button type="submit" class="ke-btn ke-btn-danger ke-btn-sm">
                                <i class="bi bi-x-lg"></i>@L["Reject"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
