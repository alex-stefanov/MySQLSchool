@model KazanlakEvents.Web.ViewModels.About.OrganizedEventFormViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@{
    Layout = "_AdminLayout";
    ViewData["AdminPage"]      = "OrganizedEvents";
    ViewData["AdminPageTitle"] = L["EditOrganizedEvent"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@L["EditOrganizedEvent"]</h1>
    <a asp-action="OrganizedEvents" class="ke-btn ke-btn-ghost ke-btn-sm">
        <i class="bi bi-arrow-left me-1"></i>@L["Back"]
    </a>
</div>

<div class="card" style="border:1px solid var(--ke-border);background:var(--ke-surface);max-width:720px;">
    <div class="card-body p-4">
        <form asp-action="EditOrganizedEvent" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold small">@L["Title"] <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold small">@L["Description"] <span class="text-danger">*</span></label>
                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CoverImageUrl" class="form-label fw-semibold small">@L["CoverImageUrl"]</label>
                <input asp-for="CoverImageUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="EventDate" class="form-label fw-semibold small">@L["EventDate"]</label>
                    <input asp-for="EventDate" type="date" class="form-control" />
                    <span asp-validation-for="EventDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AttendeesCount" class="form-label fw-semibold small">@L["AttendeesCount"]</label>
                    <input asp-for="AttendeesCount" type="number" min="0" class="form-control" />
                    <span asp-validation-for="AttendeesCount" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label fw-semibold small">@L["IsActive"]</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="ke-btn ke-btn-primary">
                    <i class="bi bi-check-lg me-1"></i>@L["Save"]
                </button>
                <a asp-action="OrganizedEvents" class="ke-btn ke-btn-ghost">@L["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
