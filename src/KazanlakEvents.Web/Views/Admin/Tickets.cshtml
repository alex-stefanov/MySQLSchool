@model TicketListViewModel
@inject IHtmlLocalizer<KazanlakEvents.Web.Resources.SharedResource> L
@using KazanlakEvents.Domain.Enums
@{
    Layout = "_AdminLayout";
    ViewData["AdminPage"] = "Tickets";
    ViewData["AdminPageTitle"] = L["Tickets"].Value;
}

<form method="get" asp-action="Tickets" asp-controller="Admin" class="card mb-4"
      style="border-radius:14px;border:0.5px solid var(--ke-border)">
    <div class="card-body d-flex flex-wrap gap-3 align-items-end" style="padding:16px 18px;">

        <div>
            <label class="form-label" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ke-text-muted);margin-bottom:4px;">@L["Event"]</label>
            <select name="eventFilter" class="form-select form-select-sm" style="min-width:180px;border-radius:8px;font-size:13px;">
                <option value="">@L["AllEvents"]</option>
                @foreach (var ev in Model.EventOptions)
                {
                    if (Model.EventFilter == ev.Id.ToString())
                    {
                        <option value="@ev.Id" selected>@ev.Title</option>
                    }
                    else
                    {
                        <option value="@ev.Id">@ev.Title</option>
                    }
                }
            </select>
        </div>

        <div>
            <label class="form-label" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ke-text-muted);margin-bottom:4px;">@L["Holder"]</label>
            <input type="text" name="userFilter" value="@Model.UserFilter" class="form-control form-control-sm"
                   placeholder="@L["SearchByUser"]" style="min-width:180px;border-radius:8px;font-size:13px;" />
        </div>

        <div>
            <label class="form-label" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ke-text-muted);margin-bottom:4px;">@L["Status"]</label>
            <select name="statusFilter" class="form-select form-select-sm" style="min-width:120px;border-radius:8px;font-size:13px;">
                <option value="">@L["All"]</option>
                @foreach (var status in Enum.GetValues<TicketStatus>())
                {
                    if (Model.StatusFilter == status.ToString())
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
        </div>

        <button type="submit" class="ke-btn ke-btn-primary" style="height:32px;font-size:13px;white-space:nowrap;">
            <i class="bi bi-funnel me-1"></i>@L["Filter"]
        </button>
        @if (!string.IsNullOrEmpty(Model.EventFilter) || !string.IsNullOrEmpty(Model.UserFilter) || !string.IsNullOrEmpty(Model.StatusFilter))
        {
            <a asp-action="Tickets" asp-controller="Admin" class="ke-btn" style="height:32px;font-size:13px;">@L["Clear"]</a>
        }
    </div>
</form>

<div class="card" style="border-radius:14px;border:0.5px solid var(--ke-border)">
    <div class="card-body p-0">
        @if (!Model.Tickets.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-ticket" style="font-size:40px;opacity:0.35;"></i>
                <div class="mt-2">@L["NoTickets"]</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0" style="font-size:13px;">
                    <thead>
                        <tr style="background:var(--ke-surface-secondary);font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--ke-text-muted)">
                            <th style="padding:10px 18px;font-weight:500">@L["TicketNumber"]</th>
                            <th style="padding:10px 12px;font-weight:500">@L["Event"]</th>
                            <th style="padding:10px 12px;font-weight:500">@L["Holder"]</th>
                            <th style="padding:10px 12px;font-weight:500">@L["TicketType"]</th>
                            <th style="padding:10px 12px;font-weight:500">@L["Status"]</th>
                            <th style="padding:10px 18px;font-weight:500;text-align:right">@L["IssuedDate"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Tickets)
                        {
                            var (bg, fg) = t.Status switch
                            {
                                TicketStatus.Valid       => ("bg-success", "text-white"),
                                TicketStatus.CheckedIn   => ("bg-primary", "text-white"),
                                TicketStatus.Cancelled   => ("bg-danger", "text-white"),
                                TicketStatus.Transferred => ("bg-warning", "text-dark"),
                                _                        => ("bg-light", "text-dark")
                            };
                            <tr style="border-bottom:0.5px solid var(--ke-border);cursor:pointer;"
                                onclick="showQrModal('@t.TicketNumber','@t.QrCode','@t.EventTitle')">
                                <td style="padding:12px 18px;vertical-align:middle;font-family:monospace;font-size:12px;font-weight:600;">
                                    #@t.TicketNumber
                                </td>
                                <td style="padding:12px;vertical-align:middle;color:var(--ke-text-secondary)">@t.EventTitle</td>
                                <td style="padding:12px;vertical-align:middle">
                                    @if (!string.IsNullOrEmpty(t.HolderName))
                                    {
                                        <div class="fw-medium">@t.HolderName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(t.HolderEmail))
                                    {
                                        <div style="font-size:11px;color:var(--ke-text-muted)">@t.HolderEmail</div>
                                    }
                                    @if (string.IsNullOrEmpty(t.HolderName) && string.IsNullOrEmpty(t.HolderEmail))
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td style="padding:12px;vertical-align:middle;color:var(--ke-text-secondary)">@t.TicketTypeName</td>
                                <td style="padding:12px;vertical-align:middle">
                                    <span class="badge @bg @fg">@t.Status</span>
                                </td>
                                <td style="padding:12px 18px;vertical-align:middle;text-align:right;color:var(--ke-text-secondary);white-space:nowrap">
                                    @t.IssuedAt.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-center gap-2 py-3" style="border-top:0.5px solid var(--ke-border)">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Tickets" asp-controller="Admin"
                           asp-route-page="@p"
                           asp-route-eventFilter="@Model.EventFilter"
                           asp-route-userFilter="@Model.UserFilter"
                           asp-route-statusFilter="@Model.StatusFilter"
                           class="ke-btn @(p == Model.CurrentPage ? "ke-btn-primary" : "")"
                           style="min-width:36px;text-align:center;font-size:13px;padding:4px 10px;">@p</a>
                    }
                </div>
            }
        }
    </div>
</div>

<div id="qr-modal" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:16px;padding:28px;max-width:340px;width:90%;text-align:center;">
        <div id="qr-event-title" style="font-size:13px;color:var(--ke-text-secondary);margin-bottom:8px;"></div>
        <div id="qr-ticket-number" style="font-size:16px;font-weight:600;font-family:monospace;margin-bottom:16px;"></div>
        <div id="qr-code-display" style="width:180px;height:180px;margin:0 auto 16px;background:var(--ke-surface-secondary);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--ke-text-muted);">
            QR Code
        </div>
        <button class="ke-btn" onclick="document.getElementById('qr-modal').style.display='none'">@L["Close"]</button>
    </div>
</div>

@section Scripts {
<script>
    function showQrModal(ticketNumber, qrCode, eventTitle) {
        document.getElementById('qr-ticket-number').textContent = '#' + ticketNumber;
        document.getElementById('qr-event-title').textContent = eventTitle;
        document.getElementById('qr-modal').style.display = '';
    }
</script>
}
